# =============================================================================
# Contoh environment variables — SALIN menjadi .env dan isi nilainya.
# JANGAN PERNAH commit file .env ke repository.
# =============================================================================

# ----- Aplikasi -----
# Domain utama, tanpa https:// (dipakai Auth.js, Nginx, Certbot)
APP_DOMAIN=lms.example.com
# URL publik lengkap
APP_URL=https://lms.example.com
# Image yang di-pull dari GHCR (diisi otomatis oleh CI)
APP_IMAGE=ghcr.io/katahugo/gladi-lms/app:latest
WORKER_IMAGE=ghcr.io/katahugo/gladi-lms/worker:latest
# Secret acak untuk Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=ganti-dengan-random-32-byte
# Google OAuth (dari Google Cloud Console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- PostgreSQL -----
POSTGRES_USER=lms
POSTGRES_PASSWORD=ganti-dengan-password-kuat
POSTGRES_DB=gladi_lms

# ----- Redis -----
REDIS_PASSWORD=ganti-dengan-password-kuat

# ----- MinIO (S3-compatible) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=ganti-dengan-password-kuat-min-8-karakter
S3_BUCKET_MEDIA=lms-media
S3_ACCESS_KEY=ganti-access-key
S3_SECRET_KEY=ganti-secret-key

# ----- Cloudflare Stream (video) -----
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
CF_STREAM_CUSTOMER_SUBDOMAIN=

# ----- Payment gateway (pilih salah satu aktif) -----
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# ----- Email transaksional (Resend) -----
RESEND_API_KEY=
EMAIL_FROM="Gladi LMS <no-reply@lms.example.com>"

# ----- Sentry (opsional, free tier cloud) -----
SENTRY_DSN=

# ----- WhatsApp -----
# Nomor WhatsApp tujuan (untuk tombol mengambang). Format internasional tanpa +.
NEXT_PUBLIC_WA_NUMBER=6281234567890

# ----- Backup (Azure Blob Storage) -----
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=lms-backups
# PENTING: SAS token mengandung karakter & yang bisa merusak parsing shell.
# BUNGKUS nilainya dengan tanda kutip tunggal (') — lihat contoh di bawah.
# Format: AZURE_STORAGE_SAS_TOKEN='sv=...&sig=...'
AZURE_STORAGE_SAS_TOKEN='sv=...&se=...&sig=...'
